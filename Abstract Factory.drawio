          <mxGeometry height="16" width="380" x="176" y="1030" as="geometry" />
        </mxCell>
        <mxCell id="flow-note" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#f3f0ff;strokeColor=#5b4fcf;fontFamily=JetBrains Mono,monospace;fontSize=10;fontColor=#1a1d27;arcSize=8;align=left;spacingLeft=10;html=1;verticalAlign=top;" value="&lt;b&gt;Family constraint — products must never cross:&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;AwsFactory   → SqsQueue         + S3Storage&lt;br/&gt;AzureFactory → ServiceBusQueue  + BlobServiceStorage&lt;br/&gt;&lt;br/&gt;InfraProvisioner only knows these 3 types:&lt;br/&gt;  CloudInfraFactory  |  MessageQueue  |  BlobStorage&lt;br/&gt;&lt;br/&gt;Never references: SqsQueue, S3Storage,&lt;br/&gt;ServiceBusQueue, BlobServiceStorage" vertex="1">
          <mxGeometry height="160" width="440" x="660" y="900" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
